model sensoresacoplamentomangueiras {
  id_sensor          Int                        @id
  id_tanque          Int                        @unique(map: "uq_sensores_acoplamento_mangueiras_id_tanque")
  status_acoplamento StatusAcoplamentoMangueira @default(DESCONHECIDA)
  sinal_detectado    Boolean                    @default(false)
  ultima_verificacao DateTime?                  @db.Timestamp(6)
  ultimo_evento_em   DateTime?                  @db.Timestamp(6)
  ativo              Boolean                    @default(true)
  criado_em          DateTime                   @default(now()) @db.Timestamp(6)
  atualizado_em      DateTime?                  @db.Timestamp(6)
  sensores           sensores                   @relation(fields: [id_sensor], references: [id_sensor], map: "fk_sensores_acoplamento_mangueiras_sensor")
  tanques            tanques                    @relation(fields: [id_tanque], references: [id_tanque], map: "fk_sensores_acoplamento_mangueiras_tanque")

  @@index([ativo], map: "idx_sensores_acoplamento_ativo")
  @@index([status_acoplamento], map: "idx_sensores_acoplamento_status_acoplamento")
}

