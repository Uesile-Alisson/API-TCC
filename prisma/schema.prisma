  @@index([id_configuracao_sistema], map: "idx_backups_id_configuracao_sistema")
  @@index([id_mqtt_configuracao], map: "idx_backups_id_mqtt_configuracao")
  @@index([id_mqtt_configuracao_historico], map: "idx_backups_id_mqtt_configuracao_historico")
