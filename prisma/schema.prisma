/// Diario persistente dos comandos enviados ao ESP32 e dos respectivos ACKs.
/// correlation_id e a chave de idempotencia compartilhada entre API e firmware.
model comandosmqtt {
  id_comando_mqtt    Int               @id @default(autoincrement())
  correlation_id     String            @unique(map: "uq_comandosmqtt_correlation_id") @db.VarChar(200)
  comando            String            @db.VarChar(80)
  status             statuscomandomqtt @default(PENDENTE)
  id_processo        Int?
  id_processo_tanque Int?
  id_usuario         Int?
  topico_publicacao  String            @db.VarChar(180)
  topico_ack         String?           @db.VarChar(180)
  payload            Json
  payload_ack        Json?
  qos                Int               @db.SmallInt
  retain             Boolean           @default(false)
  tentativas         Int               @default(0)
  publicado_em       DateTime?         @db.Timestamp(6)
  ack_recebido_em    DateTime?         @db.Timestamp(6)
  finalizado_em      DateTime?         @db.Timestamp(6)
  mensagem_ack       String?
  erro               String?
  criado_em          DateTime          @default(now()) @db.Timestamp(6)
  atualizado_em      DateTime          @default(now()) @db.Timestamp(6)
  processos          processos?        @relation(fields: [id_processo], references: [id_processo], onDelete: SetNull, onUpdate: Cascade, map: "fk_comandosmqtt_processo")
  processostanques   processostanques? @relation(fields: [id_processo_tanque], references: [id_processo_tanque], onDelete: SetNull, onUpdate: Cascade, map: "fk_comandosmqtt_processo_tanque")
  usuarios           usuarios?         @relation(fields: [id_usuario], references: [id_usuario], onDelete: SetNull, onUpdate: Cascade, map: "fk_comandosmqtt_usuario")

  @@index([status, atualizado_em], map: "idx_comandosmqtt_status_atualizado")
  @@index([id_processo, criado_em], map: "idx_comandosmqtt_processo_criado")
  @@index([id_processo_tanque, criado_em], map: "idx_comandosmqtt_processo_tanque_criado")
  @@index([id_usuario, criado_em], map: "idx_comandosmqtt_usuario_criado")
}

