NODE_ENV=development
PORT=3000
# Swagger e opt-in e nunca e publicado quando NODE_ENV=production.
SWAGGER_ENABLED=true

DATABASE_URL=
DIRECT_URL=
MONGODB_URI=

# Informações para envio de email
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
FRONTEND_RESET_PASSWORD_URL=

# Origens permitidas para HTTP e Socket.IO, separadas por virgula. Nao use curinga (*).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Deixe vazio quando a API recebe conexoes diretamente. Atras de proxy, liste apenas
# IPs, CIDRs ou nomes de sub-rede confiaveis do Express (ex.: loopback, 10.0.0.0/8).
TRUST_PROXY=
# O rate limiter atual e local ao processo. Mantenha 1; valores maiores bloqueiam
# o bootstrap ate existir um ThrottlerStorage compartilhado entre replicas.
API_INSTANCE_COUNT=1
HTTP_RATE_LIMIT_TTL_MS=60000
HTTP_RATE_LIMIT_MAX=120
HTTP_RATE_LIMIT_BLOCK_DURATION_MS=60000

# Mqtt Broker
# Caminho absoluto, fora do projeto, para o arquivo gerenciado pela API.
# Windows: C:/ProgramData/TSEA/secrets/mqtt-credentials.json
# Linux: /etc/tsea/secrets/mqtt-credentials.json
MQTT_CREDENTIALS_FILE_PATH=
MQTT_CLIENT_ID=
# Use um identificador estavel por instancia. Nao reutilize o mesmo valor em replicas simultaneas.

# JWT SECRET
JWT_SECRET=
JWT_EXPIRES_IN=

# Somente para `npm run seed:dev-users`; o seed e sempre bloqueado em producao.
# Prefira senhas locais proprias com 15 a 128 caracteres.
DEV_ADMIN_PASSWORD=
DEV_TECNICO_PASSWORD=
DEV_OPERADOR_PASSWORD=
# Habilita defaults publicos/previsiveis somente em development/test.
ALLOW_INSECURE_SEED=false
